@{
    ViewBag.Title = "Employee";
    ViewBag.SearchItem = "";
}
@model List<EmployeeResponse>
<link rel="stylesheet" href="~/bootstrap/css/bootstrap.min.css" />
<div class="container">
    <h2 class="text-center text-white bg-secondary mt-2">Employee Management</h2>
    @if (Model.Count() <= 0)
    {
        <div class="alert alert-danger">No Items to be displayed..</div>
    }
    else
    {
        <div class="row mt-2">
            <div class="col-md-6">
                <input type="search" class="form-control" placeholder="Search an employee" ViewBag.SearchItem="value" />
            </div>
            <div class="col-md-3">
                <a class="btn btn-primary" asp-controller="Employee" asp-action="GetAllEmployees" asp-route-searchText="@ViewBag.SearchItem">Search</a>
            </div>
        </div>
        <div class="mt-2">
            <div class="col-md-3">
                <a class="btn btn-primary" asp-controller="Employee" asp-action="AddNewEmployee">Add Employee</a>
                <a class="btn btn-success mx-2" asp-controller="Employee" asp-action="ExportEmployees">Export Employees</a>
            </div>
        </div>
        <table class="table table-responsive-lg table-hover mt-2">
            <thead>
                <tr>
                    @if (@ViewBag.Sort == "ASC")
                    {
                        <th><a asp-controller="Employee" asp-action="GetAllEmployees" asp-route-sortOrder="DESC" asp-route-colName="EmpName">EmpName</a></th>
                    }
                    else if (@ViewBag.Sort == "DESC")
                    {
                        <th><a asp-controller="Employee" asp-action="GetAllEmployees" asp-route-sortOrder="ASC" asp-route-colName="EmpName">EmpName</a></th>
                    }
                    else
                    {
                        <th><a asp-controller="Employee" asp-action="GetAllEmployees" asp-route-sortOrder="ASC" asp-route-colName="EmpName">EmpName</a></th>
                    }

                    <th>Email</th>
                    <th>Phone</th>
                    <th>Department</th>
                    <th>Base Location</th>
                    <th>Salary</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.EmpName</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.DepartmentName</td>
                        <td>@item.Name</td>
                        <td>@item.Salary</td>
                        <td>@item.Status</td>
                        <td>
                            <a class="btn btn-warning" asp-controller="Employee" asp-action="UpdateEmployee" asp-route-id=@item.EmpId>Edit</a>
                            <a class="btn btn-danger mx-2" asp-controller="Employee" asp-action="RemoveEmployee" asp-route-id=@item.EmpId>Remove</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    @{
        int currentPage = Convert.ToInt32(ViewBag.CurrentPage);
        int totalPage = Convert.ToInt32(ViewBag.ToTalPages);
    }

    <div>
        <ul class="pagination justify-content-end">
            <li class="page-item">
                @if (currentPage > totalPage)
                {
                    currentPage--;
                    <a class="page-link" asp-controller="Employee" asp-action="GetAllEmployees" asp-route-page=@currentPage>Previous</a>

                }
            </li>
            <li class="page-item">
                <a class="page-link" asp-controller="Employee" asp-action="GetAllEmployees" asp-route-page="1">1</a>
            </li>
            <li class="page-item"><a class="page-link" asp-controller="Employee" asp-action="GetAllEmployees" asp-route-page="2">2</a></li>
            <li class="page-item"><a class="page-link" asp-controller="Employee" asp-action="GetAllEmployees" asp-route-page="3">3</a></li>
            <li class="page-item">
                @if (currentPage < totalPage)
                {
                    currentPage++;
                    <a class="page-link" asp-controller="Employee" asp-action="GetAllEmployees" asp-route-page=@currentPage>Next</a>
                }
            </li>
        </ul>
    </div>
</div>
<script src="~/bootstrap/js/bootstrap.min.js"></script>